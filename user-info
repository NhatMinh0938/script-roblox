-- Hàm kiểm tra User có thuộc danh sách nào không
local function checkUserMode(userId)
    local activeModes = {}
    for mode, userList in pairs(UserConfigs) do
        for _, id in pairs(userList) do
            if id == userId then
                table.insert(activeModes, mode)
            end
        end
    end
    return activeModes
end

